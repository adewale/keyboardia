#!/bin/sh

# Pre-push hook: Four-phase testing
# Phase 1: Unit tests (fast, ~11s)
# Phase 2: Smoke test (fast, ~20s, Chromium only)
# Phase 3: Full E2E test (comprehensive, ~2-3min, Chromium + WebKit)
# Phase 4: Mobile Safari test (~2min, iPhone viewport + touch)
#
# REQUIRES: wrangler dev running on port 8787 (for E2E tests)
# Start with: npm run build && npx wrangler dev
#
# ─── Pipe-inheritance guard ────────────────────────────────────────────
# When git is invoked under a pipe (CI runners, tmux captures, tool
# harnesses like Claude Code) rather than a real terminal, the push will
# hang indefinitely if any process spawned by this hook outlives the hook
# while still holding git's stdout/stderr pipe open. Playwright's browser
# helpers are the likely culprit — they frequently get reparented to PID 1
# after their npm ancestor exits. Git blocks waiting for EOF on its pipe;
# the orphan never closes it.
#
# Detection: `[ -t 1 ]` returns false only when fd1 is not a terminal, i.e.
# git is being piped. In that case we redirect everything to a log file
# BEFORE spawning tests, so orphans inherit a log-file fd, not git's pipe.
# Contents are dumped to /dev/tty at exit when one is available, giving
# the user the same visibility they'd get in an interactive shell.
#
# See docs/LESSONS-LEARNED.md lesson on "pre-push hook pipe-inheritance".
if [ ! -t 1 ] || [ ! -t 2 ]; then
    # Fixed path so failures can always be inspected with `cat <path>`;
    # a per-run mktemp would be cleaner but its name is lost to git's
    # swallowed stderr, making post-mortem awkward.
    PREPUSH_LOG=/tmp/keyboardia-last-prepush.log
    rm -f "$PREPUSH_LOG"
    exec </dev/null >"$PREPUSH_LOG" 2>&1
    # The tty guard must attempt a real open: `[ -w /dev/tty ]` only checks
    # permission bits and passes in containers where /dev/tty exists but
    # opening it fails with ENXIO ("No such device or address"). That failed
    # redirect then aborts the EXIT trap under `set -e` and fails the whole
    # hook AFTER all tests passed. The subshell `( : > /dev/tty )` probes an
    # actual open without that risk.
    trap 'if ( : > /dev/tty ) 2>/dev/null; then cat "$PREPUSH_LOG" > /dev/tty || :; fi' EXIT
fi

set -e

cd app

echo ""
echo "========================================"
echo "  PRE-PUSH: Test Suite"
echo "========================================"
echo ""

# Phase 0: Manifest Validation (instant, catches silent failure bugs)
echo "----------------------------------------"
echo "Phase 0: Manifest Validation"
echo "----------------------------------------"
echo ""

if npx tsx scripts/validate-manifests.ts; then
    echo ""
    echo "✅ All manifests valid!"
    echo ""
else
    echo ""
    echo "❌ Manifest validation FAILED"
    echo ""
    echo "Fix the issues above before pushing."
    echo "Instruments with invalid manifests will be SILENT."
    echo "To skip: git push --no-verify"
    echo ""
    exit 1
fi

# Phase 1: Unit Tests (runs first, no backend required)
echo "----------------------------------------"
echo "Phase 1: Unit Tests (~11s)"
echo "----------------------------------------"
echo ""

UNIT_START=$(date +%s)

if npm run test:unit; then
    UNIT_END=$(date +%s)
    UNIT_DURATION=$((UNIT_END - UNIT_START))
    echo ""
    echo "✅ Unit tests passed! (${UNIT_DURATION}s)"
    echo ""
else
    echo ""
    echo "❌ Unit tests FAILED"
    echo ""
    echo "Fix the issues above before pushing."
    echo "To skip: git push --no-verify"
    echo ""
    exit 1
fi

# Check if wrangler dev is running (required for E2E tests)
if ! lsof -i:8787 > /dev/null 2>&1; then
    echo "❌ ERROR: wrangler dev is not running on port 8787"
    echo ""
    echo "E2E tests require the real backend for reliable results."
    echo ""
    echo "To start the backend:"
    echo "  cd app && npm run build && npx wrangler dev"
    echo ""
    echo "Then try pushing again."
    echo ""
    echo "To skip E2E tests (not recommended):"
    echo "  git push --no-verify"
    echo ""
    exit 1
fi

echo "✓ Backend detected on port 8787"
echo ""

# Phase 2: Smoke Test (fast feedback)
echo "----------------------------------------"
echo "Phase 2: Smoke Test (~20s, Chromium)"
echo "----------------------------------------"
echo ""

SMOKE_START=$(date +%s)

if npm run test:e2e:smoke; then
    SMOKE_END=$(date +%s)
    SMOKE_DURATION=$((SMOKE_END - SMOKE_START))
    echo ""
    echo "✅ Smoke test passed! (${SMOKE_DURATION}s)"
    echo ""
else
    echo ""
    echo "❌ Smoke test FAILED"
    echo ""
    echo "Fix the issues above before pushing."
    echo "To skip: git push --no-verify"
    echo ""
    exit 1
fi

# Phase 3: Full Test (comprehensive, all browsers)
echo "----------------------------------------"
echo "Phase 3: Full E2E Test (~2-3min, Chromium + WebKit)"
echo "----------------------------------------"
echo ""

FULL_START=$(date +%s)

if npm run test:e2e:full; then
    FULL_END=$(date +%s)
    FULL_DURATION=$((FULL_END - FULL_START))
    echo ""
    echo "✅ Full test passed! (${FULL_DURATION}s)"
    echo ""
else
    echo ""
    echo "❌ Full test FAILED"
    echo ""
    echo "Some tests failed on WebKit."
    echo "Review the failures above."
    echo "To skip: git push --no-verify"
    echo ""
    exit 1
fi

# Phase 4: Mobile Safari Test (iPhone viewport + touch interactions)
echo "----------------------------------------"
echo "Phase 4: Mobile Safari (~2min, iPhone)"
echo "----------------------------------------"
echo ""

MOBILE_START=$(date +%s)

if npm run test:e2e:mobile; then
    MOBILE_END=$(date +%s)
    MOBILE_DURATION=$((MOBILE_END - MOBILE_START))
    echo ""
    echo "✅ Mobile Safari test passed! (${MOBILE_DURATION}s)"
    echo ""
else
    echo ""
    echo "❌ Mobile Safari test FAILED"
    echo ""
    echo "Mobile-specific tests failed."
    echo "Review the failures above."
    echo "To skip: git push --no-verify"
    echo ""
    exit 1
fi

TOTAL_DURATION=$((UNIT_DURATION + SMOKE_DURATION + FULL_DURATION + MOBILE_DURATION))

echo "========================================"
echo "  ✅ All tests passed! (${TOTAL_DURATION}s)"
echo "  Pushing to remote..."
echo "========================================"
echo ""
